# --- Server ---
PORT=4000
NODE_ENV=development

# Comma-separated list of allowed frontend origins (CORS)
CORS_ORIGINS=http://localhost:3000

# Public storefront URL — used to build links in emails (verify email, password reset)
APP_URL=http://localhost:3000

# --- Database (MySQL) ---
# Laravel Herd default MySQL: user "root", no password, on 127.0.0.1:3306
DATABASE_URL="mysql://root@127.0.0.1:3306/luxecart"

# --- Admin seed account --- use a real, deliverable email
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-me

# --- Auth (JWT) ---
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# --- Stripe (Phase 4) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Google sign-in (social login) --- leave empty to disable the Google button
# Use the SAME OAuth Web client id on the frontend (NEXT_PUBLIC_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID=

# --- Maintenance jobs (abandoned-cart reminders + low-stock digest) ---
# Set ENABLE_SCHEDULER=true to run them hourly in-process, or trigger via
# `npm run maintenance` from cron, or POST /api/admin/maintenance/run.
ENABLE_SCHEDULER=false
ABANDONED_CART_HOURS=4
LOW_STOCK_THRESHOLD=5

# --- Email (SMTP) --- leave empty for mock mode (emails logged to console)
# Gmail setup (uses an App Password, NOT your normal Google password):
#   1. Enable 2-Step Verification on your Google account
#      https://myaccount.google.com/security
#   2. Generate an App Password (Mail / Other "LuxeCart")
#      https://myaccount.google.com/apppasswords
#   3. Paste the 16-char password (spaces or no-spaces both work) below as SMTP_PASS
# Then SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_USER=you@gmail.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=LuxeCart <no-reply@luxecart.com>

# --- SMS --- pick a provider (twilio | bulksmsbd | alphasms), or leave
# SMS_PROVIDER empty to auto-detect from creds below (mock if none set).
SMS_PROVIDER=

# Twilio (international)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# bulksmsbd.net (Bangladesh)
BULKSMSBD_API_KEY=
BULKSMSBD_SENDER_ID=

# Alpha SMS — sms.net.bd (Bangladesh)
ALPHASMS_API_KEY=
ALPHASMS_SENDER_ID=
