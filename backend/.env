# --- Server ---
PORT=4000
NODE_ENV=development

# Comma-separated list of allowed frontend origins (CORS)
CORS_ORIGINS=http://localhost:3000

# --- Database (MySQL) ---
# Laravel Herd default MySQL: user "root", no password, on 127.0.0.1:3306
DATABASE_URL="mysql://root:password@127.0.0.1:3306/luxecart"

# --- Admin seed account --- use a real, deliverable email
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-me

# --- Auth (JWT) ---
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# --- Stripe (Phase 4) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- SSLCommerz (Bangladesh: cards + bKash/Nagad/bank) ---
# Fill these from your SSLCommerz merchant panel to enable it on checkout.
# Leave blank to keep it hidden (COD + Card still work).
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_SANDBOX=true

# --- Email (SMTP) --- leave empty for mock mode (emails logged to console)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=srabonmozumder29@gmail.com
SMTP_PASS=epkplfvuvjkjqbad
MAIL_FROM=LuxeCart <srabonmozumder29@gmail.com>

# --- SMS --- pick a provider (twilio | bulksmsbd | alphasms), or leave
# SMS_PROVIDER empty to auto-detect from creds below (mock if none set).
SMS_PROVIDER=

# Twilio (international)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# bulksmsbd.net (Bangladesh)
BULKSMSBD_API_KEY=
BULKSMSBD_SENDER_ID=

# Alpha SMS — sms.net.bd (Bangladesh)
ALPHASMS_API_KEY=
ALPHASMS_SENDER_ID=
